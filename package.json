{
  "name": "afp",
  "version": "0.2.5",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "build": "tsc -b && vite build",
    "lint": "tsc --noEmit && eslint .",
    "lint:eslint": "eslint .",
    "format": "prettier --write 'src/**/*.{ts,tsx}' 'e2e/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.{ts,tsx}' 'e2e/**/*.ts'",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:debug": "PWDEBUG=1 playwright test --headed",
    "setup:env": "shx cp -n .env.example .env.development",
    "setup:env:prod": "shx cp -n .env.example .env.production",
    "setup:env:all": "bun run setup:env && bun run setup:env:prod",
    "clean": "shx rm -rf dist coverage dev-dist .final-countdown-reports",
    "clean:build": "shx rm -rf dist dev-dist",
    "clean:test": "shx rm -rf coverage test-results playwright-report e2e/screenshots e2e/results"
  },
  "dependencies": {
    "firebase": "^12.11.0",
    "lucide-react": "^1.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "firebase-admin": "^13.7.0",
    "globals": "^17.4.0",
    "jsdom": "^29.0.1",
    "prettier": "^3.8.1",
    "shx": "^0.4.0",
    "tailwindcss": "^4.2.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.3",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.2"
  }
}
